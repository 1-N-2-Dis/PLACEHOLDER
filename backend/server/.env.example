# SCAFFOLD STUB — environment variable template for the Render-hosted API.
# Copy to .env (git-ignored) for local dev; set the same names as Render env vars for deploy.
# Traces to: DEPLOYMENT_GUIDE.md, docs/12-security-compliance.md (secrets handling).

# Full JSON contents of a Firebase service account key (Firebase Console -> Project settings ->
# Service accounts -> Generate new private key). Grants Admin SDK access to Firestore + Auth.
# NEVER commit the actual key file.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Gemini key — server-side only. Never put this in any frontend .env or client code.
GEMINI_API_KEY=

# Comma-separated list of allowed frontend origins (your Vercel URL(s) + http://localhost:5173
# for local dev). Left blank, the server reflects any origin — fine to start, but set this
# explicitly before treating the deployment as production-facing.
CORS_ORIGIN=http://localhost:5173

# Render sets this automatically in production; only needed locally if you want a fixed port.
PORT=8080
