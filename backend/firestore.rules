// Firestore Security Rules for SaferRoute.
// Role: the access gate. Without deployed rules, Firestore is world-writable (Threat T1).
// Traces to: docs/09-data-model.md (rule sketch), docs/12-security-compliance.md (authz model).
//
// PRE-DEMO GATE: deploy + test these rules BEFORE demoing any write (TC-007, TC-008).
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // F-009: role lookup for the isAdmin() check below. get()/exists() reads inside rules do not
    // themselves recurse through rules, so this is safe to call from other match blocks.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // reports — public read; clients cannot write at all (F-006): the only writer is the
    // submitReport Cloud Function via the Admin SDK, which bypasses these rules — BR-005 auth,
    // the BR-001 closed enum, and the field allowlist are enforced in that function's code now.
    // Admins may delete (F-009 moderation) but never edit report content — moderation is
    // remove-only.
    match /reports/{id} {
      allow read: if true;
      allow create, update: if false;                                          // server-only, via submitReport
      allow delete: if isAdmin();                                              // F-009 moderation
    }

    // segments — public read; clients never write (seeded out-of-band by the admin script).
    match /segments/{id} {
      allow read: if true;
      allow write: if false;
    }

    // barangay_analytics_cache — pre-computed zone metrics and Gemini-generated mitigations.
    // Written only by the Admin SDK (compile-analytics.mjs batch script) — never by clients.
    // Public read so the dashboard and PDF download routes can serve data without auth.
    match /barangay_analytics_cache/{locationId} {
      allow read: if true;
      allow write: if false;
    }

    // platform_transparency_stats — single-document aggregate counters (total reports, spam
    // rejected, duplicates merged, briefs generated). Written only by compile-analytics.mjs.
    // Public read so GET /api/v1/transparency/stats requires no auth token.
    match /platform_transparency_stats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // users — role record for F-009 (email/password signup + admin moderation). A signed-in
    // user may read their own doc or (if admin) any doc; may only ever self-create as 'role: user'
    // (privilege escalation is blocked — 'admin' is assignable only out-of-band, via
    // backend/scripts/seed-auth-users.mjs's Admin SDK write, which bypasses these rules).
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.role == 'user'
        && request.resource.data.email is string
        && request.resource.data.keys().hasOnly(['email', 'role']);

      allow update, delete: if false;
    }
  }
}
