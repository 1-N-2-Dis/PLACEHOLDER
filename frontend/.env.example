# SCAFFOLD STUB — environment variable template for SaferRoute.
# Copy to .env.local and fill. .env files are git-ignored. No real values here.
# Traces to: docs/06-system-design.md + docs/12-security-compliance.md (secrets handling).

# Firebase client config — NOT secret (identifiers). Rules are the real access gate.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google One Tap / "Continue with Google" (OPTIONAL). OAuth 2.0 Web client ID — find it in
# Firebase Console → Authentication → Sign-in method → Google → Web SDK configuration, or
# Cloud Console → APIs & Services → Credentials. NOT secret (public identifier). Leave empty
# to disable One Tap entirely (the login/signup pages simply won't show a Google option).
VITE_GOOGLE_CLIENT_ID=

# Base URL of the Render-hosted API (backend/server) — submitReport/assessRoute/summarizeSegment.
# Local dev: http://localhost:8080. Production: your Render deployment URL.
VITE_API_BASE_URL=

# Google Maps JS key — ships in the client bundle BY DESIGN.
# Security comes from HTTP-referrer + API-allowlist restriction in Cloud Console, not secrecy.
VITE_MAPS_API_KEY=

# Gemini key — DO NOT put here. It must live only in backend/server/ (server-side). A Gemini key
# in the client bundle is a security failure (Threat T2). See backend/server/.env.example.
